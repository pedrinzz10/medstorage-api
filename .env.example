DB_NAME=medstorage
DB_USER=medstorage
DB_PASSWORD=medstorage
DB_PORT=5432

# JWT — substitua o secret por um valor forte em produção
JWT_SECRET=dev-only-secret-please-override-in-production-1234567890
JWT_EXPIRATION_MS=86400000

# Gmail SMTP (use uma conta dedicada de teste — nunca sua conta pessoal)
# Gere a senha de app em https://myaccount.google.com/apppasswords
MAIL_USERNAME=__REPLACE_WITH_TEST_GMAIL_ADDRESS__
MAIL_PASSWORD=__REPLACE_WITH_GMAIL_APP_PASSWORD__
MAIL_FROM_NAME=MedStorage
